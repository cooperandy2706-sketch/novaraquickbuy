# ── Supabase ──────────────────────────────────────────────────
# Get from: supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
 
# Server-only — never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
 
# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
 
# ── Storage Buckets (create in Supabase Studio > Storage) ─────
NEXT_PUBLIC_STORAGE_BUCKET_VIDEOS=novara-videos
NEXT_PUBLIC_STORAGE_BUCKET_IMAGES=novara-images
 
# ── Payment Gateway (Paystack or Flutterwave) ─────────────────
NEXT_PUBLIC_PAYMENT_GATEWAY_KEY=pk_test_...
PAYMENT_GATEWAY_SECRET=sk_test_...
 
# ── SMS (for OTP delivery) ────────────────────────────────────
SMS_API_KEY=your-sms-api-key
